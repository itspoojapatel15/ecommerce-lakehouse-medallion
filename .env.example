# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi_your_token
DATABRICKS_CATALOG=ecommerce
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# Local Delta Lake storage (for development)
DELTA_LAKE_PATH=/tmp/delta-lake/ecommerce

# PostgreSQL source (CDC)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce_source
POSTGRES_USER=cdc_reader
POSTGRES_PASSWORD=your_password

# REST API source
PRODUCT_API_URL=https://fakestoreapi.com/products
PRODUCT_API_PAGE_SIZE=50

# Quality
QUALITY_FAIL_THRESHOLD=0.95
